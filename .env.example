# BeamPay Checkout — local dev environment
# Copy to .env and fill in values

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
VITE_WC_PROJECT_ID=your_walletconnect_project_id

# BeamPay API URL (local dev or staging)
VITE_BEAM_API_URL=https://api.beampay.fun

# BeamPayRouter contract address on BSC mainnet
VITE_BEAM_PAY_ROUTER_BSC=0x0000000000000000000000000000000000000000

# BeamPayRouter contract address on Ethereum mainnet
VITE_BEAM_PAY_ROUTER_ETH=0x0000000000000000000000000000000000000000

# Test merchant address (for fixture page)
VITE_TEST_MERCHANT=0x0000000000000000000000000000000000000000

# Test USDT token address on BSC
VITE_TEST_TOKEN=0x55d398326f99059fF775485246999027B3197955
